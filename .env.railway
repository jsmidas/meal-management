# Railway PostgreSQL을 메인 DB로 사용
# 이 파일을 .env로 복사하면 Railway DB에 연결됩니다

# Railway DATABASE_URL (실제 값은 Railway 대시보드에서 확인)
DATABASE_URL=postgresql://postgres:PASSWORD@HOST:PORT/railway

# 사용 방법:
# 1. Railway 대시보드 → daham-meal-management 프로젝트 → Variables 탭
# 2. DATABASE_URL 복사
# 3. 아래에 붙여넣기

# 포트 설정
PORT=8080
