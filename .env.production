# 프로덕션 환경 설정
DATABASE_TYPE=postgresql
ENVIRONMENT=production

# Railway PostgreSQL 연결 정보 (Railway에서 자동 설정)
# DATABASE_URL은 Railway에서 자동으로 제공됨

# API 포트 (Railway/GCP 호환)
PORT=8080
API_PORT=8080

# CORS 설정
CORS_ORIGINS=["*"]

# 호스트 설정
HOST=0.0.0.0

# 디버그 모드 비활성화
DEBUG=false

# 보안 설정 (Railway 환경변수에서 오버라이드)
ADMIN_PASSWORD=SecureRailway2024!
DB_PASSWORD=SecureDBPassword2024!